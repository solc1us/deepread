{
  "name": "deepread",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.11",
      "@types/express": "^5.0.1",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.5",
      "@trpc/client": "^11.16.0",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --ui=stream",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "bun test --preload ./apps/web/src/test/setup.ts",
    "test:web": "bun run --cwd apps/web test",
    "test:e2e": "bun tests/e2e/run-e2e.ts",
    "test:e2e:headed": "bun tests/e2e/run-e2e.ts --headed",
    "test:integration": "bun run test:integration:access && bun run test:integration:reading && bun run test:integration:pipeline",
    "test:integration:access": "bun run packages/api/src/test/integration/run-access-integration.ts",
    "test:integration:reading": "bun run packages/api/src/test/integration/run-reading-integration.ts",
    "test:integration:pipeline": "bun run packages/api/src/test/integration/run-pipeline-integration.ts",
    "test:integration:migrate": "bun run packages/db/src/scripts/migrate-test-database.ts",
    "audit:database-security": "bun run packages/db/src/scripts/audit-database-security.ts",
    "validate:prisma": "bun run db:generate && bun run db:validate",
    "validate": "bun run db:generate && bun run test && bun run check-types && bun run build && bun run db:validate",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @deepread/db db:push",
    "db:studio": "turbo -F @deepread/db db:studio",
    "db:generate": "turbo run db:generate --filter=@deepread/db",
    "db:validate": "turbo run db:validate --filter=@deepread/db",
    "db:migrate": "bun run db:migrate:dev",
    "db:migrate:status": "bun run --cwd packages/db db:migrate:status",
    "db:migrate:dev": "bun run --cwd packages/db db:migrate:dev",
    "db:migrate:deploy": "bun run --cwd packages/db db:migrate:deploy",
    "db:smoke": "bun run --cwd packages/db db:smoke",
    "db:seed": "turbo -F @deepread/db db:seed"
  },
  "dependencies": {
    "@deepread/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@deepread/config": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/bun": "catalog:",
    "supabase": "^2.109.1",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
