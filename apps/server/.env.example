# Server-only runtime and Prisma values. Never expose these through NEXT_PUBLIC_* variables.
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/deepread
DIRECT_URL=postgresql://migration_user:migration_password@localhost:5432/deepread
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
PORT=3000
# Optional development seed credentials. Not used for production admin bootstrap.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
# Optional OpenAlex and diagnostics settings.
OPENALEX_API_KEY=
OPENALEX_BASE_URL=https://api.openalex.org
CLASSIFICATION_PROFILING=false
OPENALEX_INGESTION_PROFILING=false
NODE_ENV=development
