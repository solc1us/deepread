{
  "name": "server",
  "type": "module",
  "main": "src/standalone.ts",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsdown && node src/scripts/check-vercel-runtime.mjs",
    "check-types": "tsc --noEmit --composite false",
    "classifier:export-v2": "bun run src/scripts/export-classifier-v2-evaluation.ts",
    "classifier:reclassify-legacy": "bun run src/scripts/reclassify-legacy-papers.ts",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/standalone.ts --outfile server",
    "dev": "bun run --hot src/standalone.ts",
    "dev:db-health": "bun run src/scripts/dev-db-health.ts",
    "dev:classify-pending": "bun run src/scripts/dev-classify-pending.ts",
    "dev:ingest-openalex": "bun run src/scripts/dev-ingest-openalex.ts",
    "dev:test-classifier": "bun run src/scripts/dev-test-classifier.ts",
    "dev:test-openalex": "bun run src/scripts/dev-test-openalex.ts",
    "start": "bun run dist/standalone.mjs"
  },
  "dependencies": {
    "@deepread/api": "workspace:*",
    "@deepread/auth": "workspace:*",
    "@deepread/db": "workspace:*",
    "@deepread/env": "workspace:*",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "express": "^5.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@deepread/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
