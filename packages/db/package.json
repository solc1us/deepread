{
  "name": "@deepread/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit --declaration false --declarationMap false --composite false",
    "db:push": "bunx --bun prisma db push",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:seed": "bunx --bun prisma db seed",
    "db:format": "bunx --bun prisma format",
    "db:validate": "bunx --bun prisma validate",
    "postinstall": "bunx --bun prisma generate",
    "db:studio": "bunx --bun prisma studio"
  },
  "dependencies": {
    "@deepread/env": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@deepread/config": "workspace:*",
    "@types/pg": "^8.16.0",
    "prisma": "^7.8.0",
    "typescript": "catalog:"
  }
}
