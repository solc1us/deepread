enum UserRole {
  user
  admin
}

enum PaperStatus {
  pending
  needs_review
  published
  rejected
  inactive
}

enum DifficultyLevel {
  beginner_friendly
  moderate
  difficult
  expert
}

enum ReadingStatus {
  not_started
  reading
  completed
}

enum IngestionStatus {
  success
  failed
  partial
}

enum DuplicateGroupResolutionType {
  keep_both
  merge
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?  @db.Text
  papers      Paper[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Paper {
  id              String               @id @default(uuid()) @db.Uuid
  title           String               @db.Text
  abstract        String               @db.Text
  authors         Json
  publicationYear Int?                 @map("publication_year")
  doi             String?              @unique
  sourceName      String               @map("source_name")
  sourceUrl       String               @map("source_url") @db.Text
  pdfUrl          String?              @map("pdf_url") @db.Text
  categoryId      String               @map("category_id") @db.Uuid
  keywords        Json?
  language        String?
  status          PaperStatus          @default(pending)
  category        Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sources         PaperSource[]
  classification  PaperClassification?
  readingProgress ReadingProgress[]
  bookmarks       Bookmark[]
  readingNotes    ReadingNote[]
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([status])
  @@index([publicationYear])
  @@map("papers")
}

model PaperSource {
  id          String   @id @default(uuid()) @db.Uuid
  paperId     String   @map("paper_id") @db.Uuid
  provider    String
  externalId  String   @map("external_id")
  rawMetadata Json     @map("raw_metadata")
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  paper       Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([provider, externalId])
  @@index([paperId])
  @@index([provider])
  @@map("paper_sources")
}

model PaperClassification {
  id                         String          @id @default(uuid()) @db.Uuid
  paperId                    String          @unique @map("paper_id") @db.Uuid
  difficultyLevel            DifficultyLevel @map("difficulty_level")
  beginnerScore              Int?            @map("beginner_score")
  estimatedReadingTime       Int?            @map("estimated_reading_time")
  abstractLengthScore        Int?            @map("abstract_length_score")
  sentenceComplexityScore    Int?            @map("sentence_complexity_score")
  jargonDensityScore         Int?            @map("jargon_density_score")
  methodologyComplexityScore Int?            @map("methodology_complexity_score")
  statisticalComplexityScore Int?            @map("statistical_complexity_score")
  prerequisiteScore          Int?            @map("prerequisite_score")
  clarityScore               Int?            @map("clarity_score")
  classificationReason       String          @map("classification_reason") @db.Text
  readingWarning             String?         @map("reading_warning") @db.Text
  recommendedReader          String?         @map("recommended_reader") @db.Text
  classificationVersion      String          @map("classification_version")
  paper                      Paper           @relation(fields: [paperId], references: [id], onDelete: Cascade)
  createdAt                  DateTime        @default(now()) @map("created_at")
  updatedAt                  DateTime        @updatedAt @map("updated_at")

  @@index([difficultyLevel])
  @@index([beginnerScore])
  @@map("paper_classifications")
}

model AdminPaperAuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  adminUserId    String   @map("admin_user_id")
  action         String
  paperId        String   @map("paper_id") @db.Uuid
  previousValues Json?    @map("previous_values")
  newValues      Json?    @map("new_values")
  reason         String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([adminUserId])
  @@index([paperId])
  @@index([createdAt])
  @@map("admin_paper_audit_logs")
}

model DuplicateGroupResolution {
  id                String                       @id @default(uuid()) @db.Uuid
  groupKey          String                       @map("group_key") @db.Text
  groupFingerprint  String                       @unique @map("group_fingerprint")
  resolution        DuplicateGroupResolutionType
  canonicalPaperId  String?                      @map("canonical_paper_id") @db.Uuid
  paperIds          Json                         @map("paper_ids")
  duplicatePaperIds Json                         @map("duplicate_paper_ids")
  reason            String                       @db.Text
  resolvedById      String                       @map("resolved_by_id")
  resolvedBy        User                         @relation(fields: [resolvedById], references: [id], onDelete: Restrict)
  resolvedAt        DateTime                     @default(now()) @map("resolved_at")

  @@index([groupKey])
  @@index([resolution])
  @@index([canonicalPaperId])
  @@index([resolvedById])
  @@index([resolvedAt])
  @@map("duplicate_group_resolutions")
}

model ReadingProgress {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id")
  paperId            String        @map("paper_id") @db.Uuid
  status             ReadingStatus @default(not_started)
  progressPercentage Int           @default(0) @map("progress_percentage")
  startedAt          DateTime?     @map("started_at")
  completedAt        DateTime?     @map("completed_at")
  lastReadAt         DateTime?     @map("last_read_at")
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paper              Paper         @relation(fields: [paperId], references: [id], onDelete: Cascade)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@unique([userId, paperId])
  @@index([paperId])
  @@index([status])
  @@map("reading_progress")
}

model Bookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id")
  paperId   String   @map("paper_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, paperId])
  @@index([paperId])
  @@map("bookmarks")
}

model ReadingNote {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id")
  paperId   String   @map("paper_id") @db.Uuid
  note      String   @db.Text
  section   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, paperId])
  @@index([paperId])
  @@map("reading_notes")
}

model IngestionLog {
  id            String          @id @default(uuid()) @db.Uuid
  provider      String
  status        IngestionStatus
  totalFetched  Int             @default(0) @map("total_fetched")
  totalSaved    Int             @default(0) @map("total_saved")
  totalRejected Int             @default(0) @map("total_rejected")
  errorMessage  String?         @map("error_message") @db.Text
  startedAt     DateTime        @default(now()) @map("started_at")
  finishedAt    DateTime?       @map("finished_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([provider])
  @@index([status])
  @@index([startedAt])
  @@map("ingestion_logs")
}
