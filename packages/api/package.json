{
  "name": "@deepread/api",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./services/*": {
      "default": "./src/services/*.ts"
    },
    "./services/difficulty-classifier": {
      "default": "./src/services/difficulty-classifier/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit --declaration false --declarationMap false --composite false"
  },
  "dependencies": {
    "@deepread/auth": "workspace:*",
    "@deepread/db": "workspace:*",
    "@deepread/env": "workspace:*",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@deepread/config": "workspace:*",
    "@types/express": "catalog:",
    "typescript": "catalog:"
  }
}
